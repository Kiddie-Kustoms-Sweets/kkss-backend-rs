# Database
DATABASE_URL=postgres://user:password@localhost/kkss
DB_MAX_CONNECTIONS=10

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# JWT
JWT_SECRET=your-super-secret-jwt-key
JWT_ACCESS_EXPIRES_IN=7200
JWT_REFRESH_EXPIRES_IN=2592000

# Twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_PHONE=+1234567890
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_CHECKOUT_SUCCESS_URL=https://your-frontend.com/pay/success
STRIPE_CHECKOUT_CANCEL_URL=https://your-frontend.com/pay/cancel

# SevenCloud
SEVENCLOUD_USERNAME=your-sevencloud-username
SEVENCLOUD_PASSWORD=your-sevencloud-password
SEVENCLOUD_BASE_URL=https://sz.sunzee.com.cn

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
TURNSTILE_EXPECTED_HOSTNAME=api.example.com
TURNSTILE_EXPECTED_ACTION=send_code

# Resend API (Email service — works on Railway / Render / Heroku)
# Sign up at https://resend.com — free tier: 3,000 emails/day
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_FROM_EMAIL=info@kiddiekustomssweets.com
SMTP_TO_EMAIL=info@kiddiekustomssweets.com
